package com.alejandroLopez.repository;

import com.alejandroLopez.model.Equipment;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.stereotype.Repository;

import java.util.List;

@Repository
public interface EquipmentRepository extends JpaRepository<Equipment, Integer> {

    @Query(value = "SELECT e.id, c.name AS company_name, e.serial_number, e.type, e.brand, e.installation_date, e.description " +
            "FROM equipment e " +
            "JOIN company c ON e.company_id = c.id",
            nativeQuery = true)
    List<Object[]> findAllEquipmentsByCompany();


}
