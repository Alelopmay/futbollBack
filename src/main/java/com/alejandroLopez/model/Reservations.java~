package com.alejandroLopez.model;

import jakarta.persistence.*;
import lombok.Data;

@Entity
@Data
public class Reservations {
    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Integer id;

    @Column(nullable = false, length = 20)
    private String month;

    @ManyToOne
    @JoinColumn(name = "idClass", nullable = true)
    private ClassGym classGym;

    @ManyToOne
    @JoinColumn(name = "idClient", nullable = true)
    private Client client;

    public Reservations() {
    }

    public Reservations(Integer id, String month, ClassGym classGym, Client client) {
        this.id = id;
        this.month = month;
        this.classGym = classGym;
        this.client = client;
    }

    public Integer getId() {
        return id;
    }

    public void setId(Integer id) {
        this.id = id;
    }

    public String getMonth() {
        return month;
    }

    public void setMonth(String month) {
        this.month = month;
    }

    public ClassGym getClassGym() {
        return classGym;
    }

    public void setClassGym(ClassGym classGym) {
        this.classGym = classGym;
    }

    public Client getClient() {
        return client;
    }

    public void setClient(Client client) {
        this.client = client;
    }

    @Override
    public String toString() {
        return "Reservations{" +
                "id=" + id +
                ", month='" + month + '\'' +
                ", classGym=" + classGym +
                ", client=" + client +
                '}';
    }
}

